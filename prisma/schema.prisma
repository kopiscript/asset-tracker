generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String     @unique
  phone     String?
  password  String
  usertype  String     @default("user")
  createdAt DateTime?  @default(now()) @db.Timestamp(6) @map("created_at")

  vehicles Vehicle[]
  accesses VehicleAccess[]

  @@map("users")
}

model Vehicle {
  id          BigInt    @id @default(autoincrement())
  imei        String    @unique
  name        String?   @map("vehicle_name")
  plateNumber String?   @map("plate_number")
  type        String?   @map("model")
  isActive    Boolean?  @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  userId      String?   @db.Uuid @map("user_id")
  driverName  String?   @map("driver_name")

  owner            User?             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  accesses         VehicleAccess[]
  telemetryRecords TelemetryRecord[]

  @@map("vehicles")
}

// Append-only GPS + telemetry log. Never update or delete rows.
model TelemetryRecord {
  id                BigInt    @id @default(autoincrement())
  vehicleId         BigInt    @map("vehicle_id")
  imei              String
  timestampUtc      DateTime  @db.Timestamp(6) @map("timestamp_utc")
  timestampMy       DateTime  @db.Timestamp(6) @map("timestamp_my")
  latitude          Float?
  longitude         Float?
  altitude          Float?
  angle             Float?
  speedKmh          Float?    @map("speed_kmh")
  satellites        Int?
  priority          Int?
  ignition          Int?
  movement          Int?
  gnssFixType       Int?      @map("gnss_fix_type")
  gnssStatus        Int?      @map("gnss_status")
  gsmSignal         Int?      @map("gsm_signal")
  gsmOperator       String?   @map("gsm_operator")
  networkType       Int?      @map("network_type")
  externalVoltage   Float?    @map("external_voltage")
  batteryVoltage    Float?    @map("battery_voltage")
  batteryCurrent    Float?    @map("battery_current")
  batteryPercent    Int?      @map("battery_percent")
  sleepMode         Int?      @map("sleep_mode")
  dataMode          Int?      @map("data_mode")
  crashEvent        Int?      @map("crash_event")
  bleData           Int?      @map("ble_data")
  speedAlt          Float?    @map("speed_alt")
  carState          Int?      @map("car_state")
  carBatteryVoltage Float?    @map("car_battery_voltage")
  gnssRaw           String?   @map("gnss_raw")
  payload           Json      @default("{}")
  createdAt         DateTime? @default(now()) @db.Timestamp(6) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([imei, timestampUtc(sort: Desc)], map: "idx_imei_time")
  @@map("telemetry_records")
}

// Junction table: who has access to which vehicle and at what role
model VehicleAccess {
  id        String   @id @default(cuid())
  vehicleId BigInt   @map("vehicle_id")
  userId    String   @db.Uuid @map("user_id")
  role      String   // "viewer" | "editor" | "owner"
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, userId])
  @@map("vehicle_access")
}
